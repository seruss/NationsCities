@* 
    GameFlow.razor - Main SPA Orchestrator
    Switches between views based on ClientGameStateService.CurrentPhase
    Handles deep linking via RoomCodeFromUrl parameter
*@
@using NationsCities.Models
@using NationsCities.Services
@inject ClientGameStateService GameState
@inject IJSRuntime JS
@implements IDisposable

<div class="game-flow-container min-h-screen">
    @switch (_displayedPhase)
    {
        case GamePhase.Home:
            <NationsCities.Components.Game.Views.HomeView />
            break;
        case GamePhase.Lobby:
            <NationsCities.Components.Game.Views.LobbyView />
            break;
        case GamePhase.Countdown:
            @* CountdownOverlay is rendered separately below to allow fade over previous view *@
            break;
        case GamePhase.Playing:
            <div class="@(_roundEnterAnim ? "round-view-enter" : "")">
                <NationsCities.Components.Game.Views.RoundView />
            </div>
            break;
        case GamePhase.Voting:
            <NationsCities.Components.Game.Views.VotingView />
            break;
        case GamePhase.RoundResults:
            <NationsCities.Components.Game.Views.ScoreboardView />
            break;
        case GamePhase.FinalResults:
            <NationsCities.Components.Game.Views.FinalResultsView />
            break;
        case GamePhase.Disconnected:
            <NationsCities.Components.Game.Views.ReconnectingView />
            break;
        case GamePhase.Error:
            <NationsCities.Components.Game.Views.ErrorView Message="@GameState.LastError" />
            break;
    }
    
    @if (_showStopOverlayGlobal)
    {
        <NationsCities.Components.Game.Shared.StopOverlay 
            OnCovered="HandleStopCovered"
            OnFinished="HandleStopFinished" />
    }
    
    @if (_showCountdownOverlay)
    {
        <NationsCities.Components.Game.Shared.CountdownOverlay 
            Letter="@GameState.CountdownLetter"
            OnFinished="OnCountdownFinished" />
    }
</div>

<NavigationLock ConfirmExternalNavigation="@_shouldPreventNavigation" />

@* Back button confirmation modal *@
@if (_showLeaveConfirmation)
{
    <NationsCities.Components.Game.Shared.ConfirmationModal 
        Title="Opuścić grę?"
        Message="Czy na pewno chcesz opuścić aktualną grę? Twój postęp zostanie utracony."
        ConfirmText="Opuść"
        CancelText="Zostań"
        OnConfirm="ConfirmLeave"
        OnCancel="CancelLeave" />
}

@* Kicked by admin modal *@
@if (_showKickedModal)
{
    <div class="modal-overlay-anim fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm">
        <div class="bg-surface-light dark:bg-surface-dark rounded-2xl shadow-xl max-w-sm w-full p-6 space-y-4 animate-scale-in">
            <div class="flex flex-col items-center gap-3">
                <span class="material-symbols-outlined text-red-500" style="font-size: 48px;">block</span>
                <h3 class="text-xl font-bold text-slate-900 dark:text-white">Usunięto z pokoju</h3>
            </div>
            <p class="text-slate-600 dark:text-slate-400 text-center">Admin usunął Cię z pokoju.</p>
            <button @onclick="ConfirmKicked"
                    class="w-full px-4 py-3 rounded-full bg-primary text-white font-semibold
                           hover:bg-primary/90 transition-colors">
                OK
            </button>
        </div>
    </div>
}

@* New host modal *@
@if (_showNewHostModal)
{
    <div class="modal-overlay-anim fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm">
        <div class="bg-surface-light dark:bg-surface-dark rounded-2xl shadow-xl max-w-sm w-full p-6 space-y-4 animate-scale-in">
            <div class="flex flex-col items-center gap-3">
                <div class="w-16 h-16 rounded-full bg-yellow-400/20 flex items-center justify-center">
                    <span class="material-symbols-outlined text-yellow-400" style="font-size: 40px;">crown</span>
                </div>
                <h3 class="text-xl font-bold text-slate-900 dark:text-white">Jesteś teraz hostem!</h3>
            </div>
            <p class="text-slate-600 dark:text-slate-400 text-center text-sm">Poprzedni host opuścił pokój. Przejmujesz kontrolę nad grą.</p>
            <button @onclick="DismissNewHostModal"
                    class="w-full px-4 py-3 rounded-full bg-yellow-400 text-black font-semibold
                           hover:bg-yellow-300 transition-colors">
                Rozumiem!
            </button>
        </div>
    </div>
}

@code {
    [Parameter]
    public string? RoomCodeFromUrl { get; set; }
    
    private bool _initialized = false;
    private bool _showLeaveConfirmation = false;
    private bool _showKickedModal = false;
    private bool _showNewHostModal = false;
    private GamePhase _lastPhase = GamePhase.Home;
    private GamePhase _displayedPhase = GamePhase.Home;
    private bool _roundEnterAnim = false;
    private bool _showStopOverlayGlobal = false;
    private bool _showCountdownOverlay = false;
    
    private bool _shouldPreventNavigation => GameState.CurrentPhase != GamePhase.Home;

    protected override async Task OnInitializedAsync()
    {
        GameState.OnStateChanged += HandleStateChanged;
        GameState.OnNavigateAway += ShowLeaveConfirmation;
        GameState.OnKicked += ShowKickedModal;
        GameState.OnBecameHost += ShowNewHostModal;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_initialized)
        {
            _initialized = true;
            
            if (!string.IsNullOrEmpty(RoomCodeFromUrl))
            {
                // Deep link - initialize with room code
                await GameState.InitializeWithRoomCodeAsync(RoomCodeFromUrl);
            }
            else
            {
                // Normal entry - just initialize
                await GameState.InitializeAsync();
            }
            
            StateHasChanged();
        }
    }

    private void HandleStateChanged()
    {
        InvokeAsync(async () =>
        {
            if (GameState.CurrentPhase != _lastPhase)
            {
                // Smooth transition TO Countdown:
                // Keep old view (Lobby/Score) visible, render CountdownOverlay on top
                if (GameState.CurrentPhase == GamePhase.Countdown)
                {
                    _showCountdownOverlay = true;
                    _lastPhase = GameState.CurrentPhase;
                    StateHasChanged();
                    return; // _displayedPhase stays at old view (Lobby/Score)
                }
                
                // Manage STOP overlay transition from Playing -> Voting
                if (_lastPhase == GamePhase.Playing && GameState.CurrentPhase == GamePhase.Voting)
                {
                    _showStopOverlayGlobal = true;
                    _lastPhase = GameState.CurrentPhase;
                    StateHasChanged();
                    return; // Hold off updating _displayedPhase until OnCovered fires
                }
                
                // Clear round-enter animation after it played once
                if (_lastPhase == GamePhase.Countdown && GameState.CurrentPhase != GamePhase.Playing)
                {
                    _roundEnterAnim = false;
                    _showCountdownOverlay = false;
                }
                
                _displayedPhase = GameState.CurrentPhase;
                _lastPhase = GameState.CurrentPhase;
                StateHasChanged();
                await Task.Yield();
                try { await JS.InvokeVoidAsync("window.scrollTo", 0, 0); } catch { }
            }
            else
            {
                StateHasChanged();
            }
        });
    }

    private void HandleStopCovered()
    {
        // Overlay is fully opaque now. Switch the DOM behind it safely.
        _displayedPhase = GamePhase.Voting;
        StateHasChanged();
    }

    private void HandleStopFinished()
    {
        _showStopOverlayGlobal = false;
        StateHasChanged();
    }

    private async Task OnCountdownFinished()
    {
        // CountdownOverlay sequence done — swap to RoundView behind it, then remove overlay
        _roundEnterAnim = true;
        _displayedPhase = GamePhase.Playing;
        _showCountdownOverlay = false;
        GameState.FinishCountdown();
        StateHasChanged();
        
        // Remove animation class after it completes (380ms + buffer)
        await Task.Delay(500);
        _roundEnterAnim = false;
        await InvokeAsync(StateHasChanged);
    }

    private void ShowLeaveConfirmation()
    {
        _showLeaveConfirmation = true;
        InvokeAsync(StateHasChanged);
    }

    private async Task ConfirmLeave()
    {
        _showLeaveConfirmation = false;
        await GameState.LeaveGameAsync();
    }

    private void CancelLeave()
    {
        _showLeaveConfirmation = false;
        StateHasChanged();
    }

    private void ShowKickedModal()
    {
        _showKickedModal = true;
        InvokeAsync(StateHasChanged);
    }

    private async Task ConfirmKicked()
    {
        _showKickedModal = false;
        await GameState.HandleKickedAsync();
    }

    private void ShowNewHostModal()
    {
        _showNewHostModal = true;
        InvokeAsync(StateHasChanged);
    }

    private void DismissNewHostModal()
    {
        _showNewHostModal = false;
        StateHasChanged();
    }

    public void Dispose()
    {
        GameState.OnStateChanged -= HandleStateChanged;
        GameState.OnNavigateAway -= ShowLeaveConfirmation;
        GameState.OnKicked -= ShowKickedModal;
        GameState.OnBecameHost -= ShowNewHostModal;
    }
}
