    // Letter modal methods
    private void OpenLetterModal()
    {
        _selectedLetters = GameState.CurrentRoom?.Settings.AvailableLetters.ToHashSet() ?? GameSettings.DefaultPolishLetters.ToHashSet();
        _originalLetters = new HashSet<char>(_selectedLetters);
        _letterToggleState = ToggleState.Default;
        _showLetterModal = true;
    }

    private void CloseLetterModal()
    {
        _showLetterModal = false;
    }

    private void ToggleLetterSelection(char letter)
    {
        if (_selectedLetters.Contains(letter))
        {
            _selectedLetters.Remove(letter);
        }
        else
        {
            _selectedLetters.Add(letter);
        }
        _letterToggleState = ToggleState.Default;
    }

    private void CycleLetterToggle()
    {
        _letterToggleState = _letterToggleState switch
        {
            ToggleState.Default => ToggleState.All,
            ToggleState.All => ToggleState.None,
            ToggleState.None => ToggleState.Default,
            _ => ToggleState.All
        };

        if (_letterToggleState == ToggleState.All)
        {
            _selectedLetters = GameSettings.FullAlphabet.ToHashSet();
        }
        else if (_letterToggleState == ToggleState.None)
        {
            _selectedLetters.Clear();
        }
        else
        {
            _selectedLetters = new HashSet<char>(_originalLetters);
        }
    }

    private string GetLetterToggleClass() => _letterToggleState switch
    {
        ToggleState.All => "text-green-500 dark:text-green-400",
        ToggleState.None => "text-red-500 dark:text-red-400",
        _ => "text-slate-400 dark:text-slate-500 hover:text-slate-600 dark:hover:text-slate-300"
    };

    private async Task SaveLetterSettings()
    {
        if (_selectedLetters.Count < MinLetterCount) return;

        // Zachowaj kolejność z FullAlphabet
        var orderedLetters = GameSettings.FullAlphabet.Where(l => _selectedLetters.Contains(l)).ToList();
        await GameState.UpdateLetterSettingsAsync(orderedLetters);
        _showLetterModal = false;
    }

    private string GetLetterCountLabel()
    {
        var count = GameState.CurrentRoom?.Settings.AvailableLetters.Count ?? GameSettings.DefaultPolishLetters.Length;
        var total = GameSettings.FullAlphabet.Length;
        return count == total ? "Wszystkie" : $"{count} / {total}";
    }

    private string GetCategoryCountLabel()
    {
        var count = GameState.CurrentRoom?.Settings.SelectedCategories.Count ?? 0;
        if (count == 1) return "1 wybrana";
        if (count >= 2 && count <= 4) return $"{count} wybrane";
        return $"{count} wybranych";
    }

