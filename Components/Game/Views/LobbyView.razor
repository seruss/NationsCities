@* 
    LobbyView.razor - SPA Lobby View
    Converted from Lobby.razor to work with ClientGameStateService
*@
@using Microsoft.AspNetCore.SignalR.Client
@using NationsCities.Models
@using NationsCities.Services
@inject ClientGameStateService GameState
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@implements IDisposable

<PageTitle>Lobby - Państwa, Miasta</PageTitle>

@if (GameState.CurrentRoom == null)
{
    <div class="flex items-center justify-center min-h-screen bg-bg-light dark:bg-bg-dark">
        <div class="flex flex-col items-center gap-4">
            <span class="material-symbols-outlined text-4xl text-primary animate-spin">progress_activity</span>
            <p class="text-slate-500 dark:text-slate-400">Ładowanie pokoju...</p>
        </div>
    </div>
}
else
{
    var room = GameState.CurrentRoom;
    <div class="flex flex-col min-h-screen bg-bg-light dark:bg-bg-dark">
        <!-- Header -->
        <header class="sticky top-0 flex items-center justify-between p-4 bg-surface-light dark:bg-surface-dark shadow-sm z-20 border-b border-slate-200 dark:border-transparent">
            <button @onclick="ShowLeaveConfirmation" class="flex items-center justify-center w-10 h-10 rounded-full hover:bg-slate-100 dark:hover:bg-white/10 transition-colors">
                <span class="material-symbols-outlined text-slate-700 dark:text-white text-2xl">arrow_back</span>
            </button>
            <div class="flex flex-col items-center">
                <span class="text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest">Kod pokoju</span>
                <div class="flex items-center gap-2 cursor-pointer group" @onclick="CopyRoomCode">
                    <h1 class="text-2xl font-bold text-primary">@room.Code</h1>
                    <span class="material-symbols-outlined text-base text-slate-400 group-hover:text-primary">content_copy</span>
                </div>
            </div>
            <button data-theme-toggle type="button" class="flex items-center justify-center w-10 h-10 rounded-full bg-slate-100 dark:bg-white/5 hover:bg-slate-200 dark:hover:bg-white/10 transition-colors">
                <span class="material-symbols-outlined text-slate-700 dark:text-white pointer-events-none">dark_mode</span>
            </button>
        </header>

        <!-- Main Content -->
        <main class="flex-1 flex flex-col overflow-y-auto p-4 gap-4 max-w-md mx-auto w-full">
            
            <!-- Game Config (Host only) -->
            @if (IsHost)
            {
                <section class="bg-surface-light dark:bg-surface-dark rounded-2xl p-4 shadow-sm border border-slate-200 dark:border-slate-800">
                    <div class="flex items-center justify-between mb-3">
                        <h2 class="text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400">Ustawienia gry</h2>
                        <span class="px-2 py-0.5 rounded text-xs font-bold bg-primary/10 text-primary uppercase border border-primary/20">Host</span>
                    </div>

                    <!-- Row 1: Two square tiles -->
                    <div class="grid grid-cols-2 gap-3 mb-3">
                        <button @onclick="OpenCategoryModal" class="flex flex-col items-center justify-center gap-2 p-4 aspect-square rounded-xl bg-slate-100 dark:bg-surface-darker hover:bg-slate-200 dark:hover:bg-slate-800 border border-slate-200 dark:border-slate-700 transition-all group">
                            <div class="w-11 h-11 rounded-2xl bg-purple-500/10 dark:bg-purple-500/20 flex items-center justify-center">
                                <span class="material-symbols-outlined text-purple-500 dark:text-purple-400">category</span>
                            </div>
                            <span class="text-[10px] font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400">Kategorie</span>
                            <span class="text-sm font-bold text-primary">@GetCategoryCountLabel()</span>
                        </button>
                        <button @onclick="OpenLetterModal" class="flex flex-col items-center justify-center gap-2 p-4 aspect-square rounded-xl bg-slate-100 dark:bg-surface-darker hover:bg-slate-200 dark:hover:bg-slate-800 border border-slate-200 dark:border-slate-700 transition-all group">
                            <div class="w-11 h-11 rounded-2xl bg-primary/10 dark:bg-primary/20 flex items-center justify-center">
                                <span class="material-symbols-outlined text-primary">sort_by_alpha</span>
                            </div>
                            <span class="text-[10px] font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400">Litery</span>
                            <span class="text-sm font-bold text-primary">@GetLetterCountLabel()</span>
                        </button>
                    </div>

                    <!-- Row 2: Round count with inline +/- -->
                    <div class="flex items-center justify-between p-3 rounded-xl bg-slate-100 dark:bg-surface-darker border border-slate-200 dark:border-slate-700 mb-3">
                        <div class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-cyan-500 dark:text-cyan-400">repeat</span>
                            <div class="flex flex-col">
                                <span class="text-sm font-bold text-slate-900 dark:text-white">Liczba rund</span>
                                <span class="text-xs text-slate-500 dark:text-slate-400">@room.Settings.RoundCount @GetRoundWord(room.Settings.RoundCount)</span>
                            </div>
                        </div>
                        <div class="flex items-center gap-2">
                            <button @onclick="DecrementRoundsInline" disabled="@(room.Settings.RoundCount <= 1)" class="w-8 h-8 rounded-lg bg-slate-200 dark:bg-slate-700 hover:bg-slate-300 dark:hover:bg-slate-600 flex items-center justify-center transition-colors disabled:opacity-40 disabled:cursor-not-allowed">
                                <span class="material-symbols-outlined text-slate-600 dark:text-slate-300 text-lg">remove</span>
                            </button>
                            <button @onclick="IncrementRoundsInline" disabled="@(room.Settings.RoundCount >= MaxRoundCount)" class="w-8 h-8 rounded-lg bg-slate-200 dark:bg-slate-700 hover:bg-slate-300 dark:hover:bg-slate-600 flex items-center justify-center transition-colors disabled:opacity-40 disabled:cursor-not-allowed">
                                <span class="material-symbols-outlined text-slate-600 dark:text-slate-300 text-lg">add</span>
                            </button>
                        </div>
                    </div>

                    <!-- Row 3: Public/Private Toggle -->
                    <div class="flex items-center justify-between p-3 rounded-xl @(room.IsPublic ? "bg-green-500/15 border-green-500/30 dark:bg-green-900/30 dark:border-green-700/50" : "bg-slate-100 border-slate-200 dark:bg-surface-darker dark:border-slate-700") border transition-all">
                        <div class="flex items-center gap-2">
                            <span class="material-symbols-outlined @(room.IsPublic ? "text-green-600 dark:text-green-400" : "text-slate-500 dark:text-slate-400")">@(room.IsPublic ? "visibility" : "visibility_off")</span>
                            <div class="flex flex-col">
                                <span class="text-sm font-bold @(room.IsPublic ? "text-green-600 dark:text-green-400" : "text-slate-900 dark:text-white")">@(room.IsPublic ? "Pokój publiczny" : "Pokój prywatny")</span>
                                <span class="text-xs text-slate-500 dark:text-slate-400">@(room.IsPublic ? "Widoczny dla wszystkich" : "Tylko z kodem")</span>
                            </div>
                        </div>
                        <label class="toggle-switch @(room.IsPublic ? "checked" : "")" @onclick="ToggleRoomVisibility">
                            <div class="toggle-slider"></div>
                        </label>
                    </div>
                </section>
            }

            <!-- Players List -->
            <div class="flex items-center justify-between px-1">
                <h3 class="text-lg font-bold text-slate-900 dark:text-white">
                    Gracze <span class="text-slate-500 dark:text-slate-400 text-base font-medium ml-1">(@room.Players.Count/@room.Settings.MaxPlayers)</span>
                </h3>
                <div class="flex items-center gap-1 bg-green-500/10 px-2 py-0.5 rounded-full border border-green-500/20">
                    <span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></span>
                    <span class="text-xs text-green-500 dark:text-green-400 font-bold uppercase">Online</span>
                </div>
            </div>

            <div class="flex flex-col gap-3">
                @foreach (var player in room.Players)
                {
                    var isMe = player.Nickname == GameState.Nickname;
                    <div class="flex items-center gap-3 p-2 pr-4 bg-surface-light dark:bg-surface-dark rounded-full shadow-sm border @(player.IsHost ? "border-primary/20" : "border-slate-200 dark:border-slate-800") relative overflow-hidden">
                        @if (player.IsHost)
                        {
                            <div class="absolute inset-0 bg-gradient-to-r from-primary/5 to-transparent pointer-events-none"></div>
                        }
                        <!-- Avatar -->
                        <div class="relative z-10">
                            <div class="h-10 w-10 rounded-full flex items-center justify-center text-sm font-bold text-white avatar-initials"
                                 style="background-color: @player.AvatarColor">
                                @player.GetInitials()
                            </div>
                            @if (player.IsHost)
                            {
                                <div class="absolute -bottom-0.5 -right-0.5 w-4 h-4 bg-yellow-400 text-black rounded-full border border-surface-light dark:border-surface-dark flex items-center justify-center">
                                    <span class="material-symbols-outlined" style="font-size: 10px;">crown</span>
                                </div>
                            }
                        </div>
                        <!-- Info -->
                        <div class="flex-1 flex flex-col z-10">
                            <div class="flex items-center gap-2">
                                <span class="text-sm font-bold text-slate-900 dark:text-white">@player.Nickname</span>
                                @if (isMe)
                                {
                                    <span class="text-xs text-slate-500 dark:text-slate-400">(Ty)</span>
                                }
                                @if (player.IsHost)
                                {
                                    <span class="px-1.5 py-0.5 rounded-sm bg-primary/10 text-[9px] font-bold text-primary uppercase">Host</span>
                                }
                            </div>
                        </div>
                        <!-- Ready Status -->
                        <div class="z-10 px-3 py-1 @(player.IsReady ? "bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400" : "bg-slate-200 dark:bg-slate-700 text-slate-600 dark:text-slate-300") rounded-full text-xs font-bold flex items-center gap-1">
                            <span class="material-symbols-outlined text-sm">@(player.IsReady ? "check" : "hourglass_empty")</span>
                            @(player.IsReady ? "Gotowy" : "Czeka")
                        </div>
                        <!-- Kick (Host only, not self) -->
                        @if (IsHost && !isMe)
                        {
                            <button @onclick="() => KickPlayer(player.ConnectionId)" 
                                    class="ml-1 w-8 h-8 flex items-center justify-center shrink-0 text-slate-400 hover:text-red-500 transition-colors rounded-full hover:bg-red-100 dark:hover:bg-red-900/20 focus:outline-none focus-visible:ring-2 focus-visible:ring-red-500/50">
                                <span class="material-symbols-outlined text-lg">block</span>
                            </button>
                        }
                    </div>
                }

                <!-- Empty Slot -->
                @if (room.Players.Count != room.Settings.MaxPlayers)
                {
                    <div class="flex items-center gap-3 p-2 pr-4 border border-dashed border-slate-300 dark:border-slate-700 rounded-full">
                        <div class="h-10 w-10 rounded-full bg-slate-200 dark:bg-slate-800 flex items-center justify-center">
                            <span class="material-symbols-outlined text-slate-400 dark:text-slate-600 text-xl">add</span>
                        </div>
                        <span class="text-sm font-medium text-slate-400 dark:text-slate-500">Oczekiwanie na gracza...</span>
                    </div>
                }
            </div>

            <!-- Chat -->
            <NationsCities.Components.Game.Shared.ChatBox Variant="NationsCities.Components.Game.Shared.ChatBox.ChatVariant.Inline" MaxMessages="10" ShowHeader="false" />
        </main>

        <!-- Footer Actions -->
        <footer class="sticky bottom-0 p-4 bg-surface-light dark:bg-surface-dark border-t border-slate-200 dark:border-slate-800 z-20 w-full max-w-md mx-auto safe-area-bottom">
            <div class="flex justify-between items-center mb-3 text-xs px-1">
                <span class="text-slate-500 dark:text-slate-400">Gotowość: <span class="font-bold text-slate-900 dark:text-white">@ReadyCount/@room.Players.Count</span></span>
                @if (!AllReady)
                {
                    <span class="text-orange-400 font-medium flex items-center gap-1">
                        <span class="material-symbols-outlined" style="font-size: 14px;">info</span>
                        Czeka na @(room.Players.Count - ReadyCount) @GetPlayerWord(room.Players.Count - ReadyCount)
                    </span>
                }
            </div>
            <div class="flex gap-3">
                <button @onclick="ShowLeaveConfirmation" class="w-12 h-12 flex items-center justify-center rounded-xl bg-slate-200 dark:bg-slate-800 text-slate-500 dark:text-slate-400 hover:text-red-400 hover:bg-red-100 dark:hover:bg-red-900/20 transition-colors">
                    <span class="material-symbols-outlined">logout</span>
                </button>
                @if (IsHost)
                {
                    <button @onclick="StartGame" 
                            disabled="@(!CanStart)"
                            class="flex-1 h-12 @(CanStart ? "bg-primary hover:bg-primary-dark" : "bg-slate-200 dark:bg-slate-700 cursor-not-allowed") text-white rounded-xl flex items-center justify-center gap-2 shadow-lg shadow-primary/20 transition-all btn-press">
                        <span class="text-base font-bold uppercase">Rozpocznij grę</span>
                        <span class="material-symbols-outlined">play_arrow</span>
                    </button>
                }
                else
                {
                    <button @onclick="ToggleReady"
                            class="flex-1 h-12 @(AmIReady ? "bg-green-600 hover:bg-green-700" : "bg-primary hover:bg-primary-dark") text-white rounded-xl flex items-center justify-center gap-2 shadow-lg transition-all btn-press">
                        <span class="text-base font-bold uppercase">@(AmIReady ? "Gotowy ✓" : "Jestem gotowy")</span>
                    </button>
                }
            </div>
        </footer>
    </div>

    <!-- Category Selection Modal -->
    @if (_showCategoryModal)
    {
        <div class="modal-backdrop" @onclick="CloseCategoryModal">
            <div class="modal-content category-list-modal" @onclick:stopPropagation="true">
                <div class="modal-header">
                    <button @onclick="CloseCategoryModal" class="text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors">
                        <span class="material-symbols-outlined text-2xl">arrow_back</span>
                    </button>
                    <h2 class="text-lg font-bold text-slate-900 dark:text-white flex-1 text-center">Kategorie</h2>
                    <button @onclick="CycleCategoryToggle" class="@GetCategoryToggleClass() transition-colors">
                        <span class="material-symbols-outlined text-2xl">checklist</span>
                    </button>
                </div>

                <div class="modal-body category-modal-body">
                    <div class="flex items-center gap-2 bg-surface-light dark:bg-surface-dark rounded-xl p-2 pl-4 mb-4 border border-slate-200 dark:border-slate-700 overflow-hidden">
                        <span class="material-symbols-outlined text-slate-400 shrink-0">edit</span>
                        <input @bind="_customCategoryInput" @bind:event="oninput" class="no-focus-glow bg-transparent border-none text-sm text-slate-900 dark:text-white placeholder-slate-400 flex-1 min-w-0 focus:ring-0 focus:outline-none p-0" placeholder="Nowa kategoria..." type="text" />
                        <button @onclick="AddCustomCategory" disabled="@(string.IsNullOrWhiteSpace(_customCategoryInput))" class="@(string.IsNullOrWhiteSpace(_customCategoryInput) ? "bg-slate-300 dark:bg-slate-600 text-slate-400 dark:text-slate-500 cursor-not-allowed" : "bg-primary hover:bg-primary-dark text-white") rounded-lg w-10 h-10 flex items-center justify-center transition-colors shrink-0">
                            <span class="material-symbols-outlined">add</span>
                        </button>
                    </div>

                    <div class="flex flex-col">
                        @foreach (var item in _categoriesWithColors)
                        {
                            var isSelected = _selectedCategoryNames.Contains(item.Category.Name);
                            <div @onclick="() => ToggleCategorySelection(item.Category.Name)" 
                                 class="group flex items-center gap-4 px-2 py-3 cursor-pointer hover:bg-slate-100 dark:hover:bg-slate-800/50 transition-colors border-b border-slate-200 dark:border-slate-800/50 rounded">
                                <div class="flex items-center justify-center w-10 h-10 rounded-full @item.BgClass @item.TextClass">
                                    <span class="material-symbols-outlined">@item.Category.Icon</span>
                                </div>
                                <div class="flex flex-col flex-1 overflow-hidden">
                                    <p class="text-slate-900 dark:text-white text-base font-semibold leading-normal truncate">@item.Category.Name</p>
                                </div>
                                <div class="shrink-0">
                                    <label class="toggle-switch @(isSelected ? "checked" : "")">
                                        <div class="toggle-slider"></div>
                                    </label>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div class="modal-footer">
                    <button @onclick="SaveCategorySettings" 
                            disabled="@(_selectedCategoryNames.Count == 0)"
                            class="w-full h-12 bg-primary hover:bg-blue-600 text-white rounded-xl font-bold transition-colors shadow-lg shadow-blue-500/20 active:scale-[0.98] disabled:opacity-50 disabled:cursor-not-allowed">
                        Zapisz
                    </button>
                </div>
            </div>
        </div>
    }

    <!-- Letter Selection Modal -->
    @if (_showLetterModal)
    {
        <div class="modal-backdrop" @onclick="CloseLetterModal">
            <div class="modal-content category-list-modal" @onclick:stopPropagation="true">
                <div class="modal-header">
                    <button @onclick="CloseLetterModal" class="text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors">
                        <span class="material-symbols-outlined text-2xl">arrow_back</span>
                    </button>
                    <h2 class="text-lg font-bold text-slate-900 dark:text-white flex-1 text-center">Wybór liter</h2>
                    <button @onclick="CycleLetterToggle" class="@GetLetterToggleClass() transition-colors">
                        <span class="material-symbols-outlined text-2xl">checklist</span>
                    </button>
                </div>

                <div class="modal-body">
                    <div class="grid grid-cols-5 gap-2">
                        @foreach (var letter in GameSettings.FullAlphabet)
                        {
                            var isSelected = _selectedLetters.Contains(letter);
                            <button @onclick="() => ToggleLetterSelection(letter)"
                                    class="@(isSelected ? "bg-primary text-white shadow-md" : "bg-slate-100 dark:bg-slate-800 text-slate-400 dark:text-slate-600") aspect-square flex items-center justify-center rounded-xl font-bold text-lg transition-all btn-press">
                                @letter
                            </button>
                        }
                    </div>
                    <p class="text-xs text-center mt-4 @(_selectedLetters.Count < MinLetterCount ? "text-red-400" : "text-slate-500 dark:text-slate-400")">
                        Wybrano: <span class="font-bold">@_selectedLetters.Count</span> / @GameSettings.FullAlphabet.Length
                        @if (_selectedLetters.Count < MinLetterCount)
                        {
                            <span> · min. @MinLetterCount</span>
                        }
                    </p>
                </div>

                <div class="modal-footer">
                    <button @onclick="SaveLetterSettings" 
                            disabled="@(_selectedLetters.Count < MinLetterCount)"
                            class="w-full h-12 bg-primary hover:bg-primary-dark text-white rounded-xl font-bold transition-colors shadow-lg shadow-blue-500/20 active:scale-[0.98] disabled:opacity-50 disabled:cursor-not-allowed">
                        Zapisz
                    </button>
                </div>
            </div>
        </div>
    }

    @if (_showLeaveConfirmation)
    {
        <NationsCities.Components.Game.Shared.ConfirmationModal 
            Title="Opuścić pokój?"
            Message="Czy na pewno chcesz opuścić pokój?"
            ConfirmText="Opuść"
            CancelText="Zostań"
            OnConfirm="ConfirmLeave"
            OnCancel="CancelLeave" />
    }
}

@code {
    // Modal state
    private bool _showCategoryModal = false;
    private bool _showLetterModal = false;
    private bool _showLeaveConfirmation = false;
    private HashSet<string> _selectedCategoryNames = new();
    private HashSet<char> _selectedLetters = new();
    private HashSet<string> _originalCategoryNames = new();
    private HashSet<char> _originalLetters = new();
    private string _customCategoryInput = "";

    // 3-state toggle: Default (white), All (blue), None (faded)
    private enum ToggleState { Default, All, None }
    private ToggleState _categoryToggleState = ToggleState.Default;
    private ToggleState _letterToggleState = ToggleState.Default;

    private record CategoryWithColor(Category Category, string BgClass, string TextClass);
    private List<CategoryWithColor> _categoriesWithColors = new();

    private int MinLetterCount => GameState.CurrentRoom?.Settings.RoundCount ?? 5;
    private int MaxRoundCount => GameState.CurrentRoom?.Settings.AvailableLetters.Count ?? GameSettings.DefaultPolishLetters.Length;

    private bool IsHost => GameState.CurrentRoom?.Players.FirstOrDefault(p => p.Nickname == GameState.Nickname)?.IsHost ?? false;
    private bool AmIReady => GameState.CurrentRoom?.Players.FirstOrDefault(p => p.Nickname == GameState.Nickname)?.IsReady ?? false;
    private int ReadyCount => GameState.CurrentRoom?.Players.Count(p => p.IsReady) ?? 0;
    private bool AllReady => GameState.CurrentRoom?.Players.All(p => p.IsReady) ?? false;
    private bool CanStart => AllReady && (GameState.CurrentRoom?.Players.Count ?? 0) >= 2;

    protected override void OnInitialized()
    {
        GameState.OnStateChanged += HandleStateChanged;
        GameState.OnChatMessage += HandleChatMessage;
        InitializeCategoryColors();
    }

    private void InitializeCategoryColors()
    {
        var colorSchemes = new[]
        {
            ("bg-blue-100 dark:bg-blue-900/30", "text-blue-600 dark:text-blue-400"),
            ("bg-purple-100 dark:bg-purple-900/30", "text-purple-600 dark:text-purple-400"),
            ("bg-green-100 dark:bg-green-900/30", "text-green-600 dark:text-green-400"),
            ("bg-emerald-100 dark:bg-emerald-900/30", "text-emerald-600 dark:text-emerald-400"),
            ("bg-orange-100 dark:bg-orange-900/30", "text-orange-600 dark:text-orange-400"),
            ("bg-red-100 dark:bg-red-900/30", "text-red-600 dark:text-red-400"),
            ("bg-teal-100 dark:bg-teal-900/30", "text-teal-600 dark:text-teal-400"),
            ("bg-pink-100 dark:bg-pink-900/30", "text-pink-600 dark:text-pink-400"),
            ("bg-yellow-100 dark:bg-yellow-900/30", "text-yellow-600 dark:text-yellow-400"),
            ("bg-indigo-100 dark:bg-indigo-900/30", "text-indigo-600 dark:text-indigo-400"),
        };

        _categoriesWithColors = Category.StandardCategories
            .Select((cat, index) => new CategoryWithColor(cat, colorSchemes[index % colorSchemes.Length].Item1, colorSchemes[index % colorSchemes.Length].Item2))
            .ToList();
    }

    private void HandleStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private async Task ToggleReady()
    {
        var currentPlayer = GameState.CurrentRoom?.Players.FirstOrDefault(p => p.Nickname == GameState.Nickname);
        if (currentPlayer != null)
        {
            await GameState.SetReadyAsync(!currentPlayer.IsReady);
        }
    }

    private async Task ToggleRoomVisibility()
    {
        if (GameState.CurrentRoom != null && IsHost)
        {
            await GameState.SetRoomPublicAsync(!GameState.CurrentRoom.IsPublic);
        }
    }

    private async Task LeaveRoom()
    {
        await GameState.LeaveGameAsync();
    }

    private void ShowLeaveConfirmation()
    {
        _showLeaveConfirmation = true;
    }

    private async Task ConfirmLeave()
    {
        _showLeaveConfirmation = false;
        await GameState.LeaveGameAsync();
    }

    private void CancelLeave()
    {
        _showLeaveConfirmation = false;
    }

    private async Task KickPlayer(string connectionId)
    {
        await GameState.KickPlayerAsync(connectionId);
    }

    private async Task StartGame()
    {
        await GameState.StartGameAsync();
    }

    private async Task CopyRoomCode()
    {
        if (GameState.CurrentRoom != null)
        {
            try
            {
                await JSRuntime.InvokeVoidAsync("copyToClipboard", GameState.CurrentRoom.Code);
            }
            catch { }
        }
    }

    // Modal methods
    private void OpenCategoryModal()
    {
        _selectedCategoryNames = GameState.CurrentRoom?.Settings.SelectedCategories.Select(c => c.Name).ToHashSet() ?? new();
        _originalCategoryNames = new HashSet<string>(_selectedCategoryNames);
        _categoryToggleState = ToggleState.Default;
        _showCategoryModal = true;
    }

    private void CloseCategoryModal()
    {
        _showCategoryModal = false;
    }

    private void ToggleCategorySelection(string categoryName)
    {
        if (_selectedCategoryNames.Contains(categoryName))
        {
            _selectedCategoryNames.Remove(categoryName);
        }
        else
        {
            _selectedCategoryNames.Add(categoryName);
        }
        _categoryToggleState = ToggleState.Default;
    }

    private void CycleCategoryToggle()
    {
        _categoryToggleState = _categoryToggleState switch
        {
            ToggleState.Default => ToggleState.All,
            ToggleState.All => ToggleState.None,
            ToggleState.None => ToggleState.Default,
            _ => ToggleState.All
        };

        if (_categoryToggleState == ToggleState.All)
        {
            _selectedCategoryNames = _categoriesWithColors.Select(c => c.Category.Name).ToHashSet();
        }
        else if (_categoryToggleState == ToggleState.None)
        {
            _selectedCategoryNames.Clear();
        }
        else
        {
            _selectedCategoryNames = new HashSet<string>(_originalCategoryNames);
        }
    }

    private string GetCategoryToggleClass() => _categoryToggleState switch
    {
        ToggleState.All => "text-green-500 dark:text-green-400",
        ToggleState.None => "text-red-500 dark:text-red-400",
        _ => "text-slate-400 dark:text-slate-500 hover:text-slate-600 dark:hover:text-slate-300"
    };

    private async Task SaveCategorySettings()
    {
        if (_selectedCategoryNames.Count == 0 || GameState.CurrentRoom == null) return;

        await GameState.UpdateGameSettingsAsync(_selectedCategoryNames.ToList(), GameState.CurrentRoom.Settings.RoundCount);
        _showCategoryModal = false;
    }

    private void AddCustomCategory()
    {
        if (string.IsNullOrWhiteSpace(_customCategoryInput)) return;

        if (_categoriesWithColors.Any(c => c.Category.Name.Equals(_customCategoryInput.Trim(), StringComparison.OrdinalIgnoreCase)))
        {
            _customCategoryInput = "";
            return;
        }

        var customCategory = new Category
        {
            Name = _customCategoryInput.Trim(),
            Icon = "star",
            IsCustom = true
        };

        _categoriesWithColors.Add(new CategoryWithColor(customCategory, "bg-primary/20", "text-primary"));
        _selectedCategoryNames.Add(customCategory.Name);
        _customCategoryInput = "";
    }

