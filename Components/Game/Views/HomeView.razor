@* 
    HomeView.razor - SPA Home View
*@
@using Microsoft.AspNetCore.SignalR.Client
@using NationsCities.Models
@using NationsCities.Services
@inject ClientGameStateService GameState
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Państwa, Miasta</PageTitle>

<!-- Single layout shell – hero stays anchored, only footer changes -->
<div class="flex flex-col min-h-screen bg-bg-light dark:bg-bg-dark">

    <!-- Header -->
    <header class="relative z-10 flex items-center justify-between p-4 pb-2">
        @if (_showJoinInput)
        {
            <button @onclick="CancelForm"
                    class="flex items-center justify-center w-10 h-10 rounded-full hover:bg-slate-100 dark:hover:bg-white/10 transition-colors">
                <span class="material-symbols-outlined text-slate-700 dark:text-white text-2xl">arrow_back</span>
            </button>
        }
        else
        {
            <div class="w-10"></div>
        }
        <button data-theme-toggle
                type="button"
                class="flex w-12 h-12 items-center justify-center rounded-full text-slate-500 dark:text-slate-400 hover:bg-slate-200 dark:hover:bg-slate-700/50 transition-colors cursor-pointer">
            <span class="material-symbols-outlined text-2xl pointer-events-none">light_mode</span>
        </button>
    </header>

    <!-- Hero – always centered, always visible -->
    <main class="flex-1 flex flex-col items-center justify-center px-4 -mt-6">
        <div class="relative mb-6">
            <div class="absolute inset-0 bg-primary/30 rounded-full scale-150" style="filter: blur(80px);"></div>
            <div class="relative flex items-center justify-center bg-gradient-to-br from-surface-light to-bg-light dark:from-surface-dark dark:to-bg-dark shadow-lg border border-slate-200 dark:border-slate-800" style="height: 12rem; width: 12rem; border-radius: 3.5rem;">
                <span class="material-symbols-outlined text-primary" style="font-size: 120px;">public</span>
                <div class="absolute -bottom-3 -right-3 flex items-center justify-center bg-bg-light dark:bg-bg-dark border-4 border-bg-light dark:border-bg-dark shadow-sm" style="height: 3.5rem; width: 3.5rem; border-radius: 1.1rem;">
                    <div class="flex h-full w-full items-center justify-center bg-green-500/20" style="border-radius: 0.85rem;">
                        <span class="material-symbols-outlined text-green-400 text-2xl">shield_lock</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="flex flex-col gap-1.5 text-center max-w-md mx-auto">
            <h1 class="text-slate-900 dark:text-white tracking-tight text-3xl font-bold leading-tight">Państwa, Miasta</h1>
            <p class="text-slate-500 dark:text-slate-400 text-sm leading-relaxed px-4">
                Klasyczna gra towarzyska z systemem anty-cheat.
            </p>
        </div>
    </main>

    <!-- Footer – changes based on state -->
    <footer class="w-full px-4 pt-3 pb-12 safe-area-bottom">
        <div class="mx-auto max-w-md flex flex-col gap-3">

            @if (!_showJoinInput)
            {
                <!-- ---- SCREEN 1: dwa przyciski ---- -->

                @if (!string.IsNullOrEmpty(_kickedMessage))
                {
                    <div class="flex items-center gap-3 p-4 rounded-xl bg-red-500/10 border border-red-500/30 animate-fade-in">
                        <span class="material-symbols-outlined text-red-500 text-2xl shrink-0">block</span>
                        <div class="flex-1">
                            <p class="text-sm font-semibold text-red-500">@_kickedMessage</p>
                        </div>
                        <button @onclick="DismissKickedMessage" class="shrink-0 text-slate-400 hover:text-slate-600 dark:hover:text-slate-300 transition-colors">
                            <span class="material-symbols-outlined text-lg">close</span>
                        </button>
                    </div>
                }

                <button @onclick="ShowNicknameForCreate"
                        class="flex w-full items-center justify-center rounded-full h-14 px-5 bg-primary hover:bg-primary-dark transition-all text-white shadow-lg shadow-primary/25 btn-press">
                    <span class="material-symbols-outlined mr-2 text-2xl">add_circle</span>
                    <span class="text-lg font-bold">Stwórz pokój</span>
                </button>

                <button @onclick="ShowJoinInput"
                        class="flex w-full items-center justify-center rounded-full h-14 px-5 bg-surface-light dark:bg-surface-dark border border-slate-300 dark:border-slate-700 hover:bg-slate-100 dark:hover:bg-slate-800 transition-all text-slate-900 dark:text-white btn-press">
                    <span class="material-symbols-outlined mr-2 text-2xl">login</span>
                    <span class="text-lg font-bold">Dołącz do pokoju</span>
                </button>



                <div class="flex justify-center">
                    <button @onclick="GoToHowToPlay" class="flex items-center gap-1.5 text-sm font-medium text-slate-500 dark:text-slate-400 hover:text-primary transition-colors py-2 px-4 rounded-full hover:bg-slate-200/50 dark:hover:bg-slate-800/50">
                        <span class="material-symbols-outlined text-lg">info</span>
                        <span>Jak grać?</span>
                    </button>
                </div>
            }
            else if (_isCreating)
            {
                <!-- ---- SCREEN 2a: tworzenie pokoju ---- -->
                <!-- Dokładnie te same rozmiary co 2 główne przyciski na ekranie 1 -->
                <input @bind="_nickname"
                       @bind:event="oninput"
                       placeholder="Twój nick"
                       maxlength="20"
                       class="w-full h-14 px-5 rounded-full bg-surface-light dark:bg-surface-dark border border-slate-300 dark:border-slate-700 text-slate-900 dark:text-white text-center text-lg placeholder:text-slate-400 dark:placeholder:text-slate-500 focus:border-primary transition-all" />

                <button @onclick="SubmitForm"
                        disabled="@(!CanSubmit || _isLoading)"
                        class="@GetSubmitButtonClass()">
                    @if (_isLoading)
                    {
                        <div class="w-6 h-6 border-2 border-white border-t-transparent rounded-full animate-spin mr-2"></div>
                        <span class="text-lg font-bold">Tworzę pokój...</span>
                    }
                    else
                    {
                        <span class="material-symbols-outlined mr-2 text-2xl">add_circle</span>
                        <span class="text-lg font-bold">Stwórz pokój</span>
                    }
                </button>

                @if (!string.IsNullOrEmpty(_error))
                {
                    <p class="text-center text-red-400 text-sm">@_error</p>
                }

                <!-- Anuluj – ta sama pozycja co "Jak grać?" na ekranie 1 -->
                <div class="flex justify-center">
                    <button @onclick="CancelForm" class="flex items-center gap-1.5 text-sm font-medium text-slate-500 dark:text-slate-400 hover:text-primary transition-colors py-2 px-4 rounded-full hover:bg-slate-200/50 dark:hover:bg-slate-800/50">
                        <span class="material-symbols-outlined text-lg">close</span>
                        <span>Anuluj</span>
                    </button>
                </div>
            }
            else
            {
                <!-- ---- SCREEN 2b: dołączanie ---- -->
                <div class="flex flex-col gap-3 pb-1">

                    <!-- Nick – h-14 rounded-full jak przyciski na ekranie 1 -->
                    <div class="relative">
                        <input @bind="_nickname"
                               @bind:event="oninput"
                               placeholder="Twój nick..."
                               maxlength="20"
                               class="w-full h-14 pl-6 pr-14 rounded-full bg-surface-light dark:bg-surface-dark border border-slate-300 dark:border-slate-700 text-slate-900 dark:text-white placeholder:text-slate-400 dark:placeholder:text-slate-500 focus:border-primary transition-all text-base" />
                        <span class="material-symbols-outlined absolute right-5 top-1/2 -translate-y-1/2 text-slate-400 dark:text-slate-500 text-xl pointer-events-none">person</span>
                    </div>

                    <!-- Pokoje publiczne -->
                    @if (_isLoadingRooms)
                    {
                        <div class="flex justify-center py-2">
                            <span class="material-symbols-outlined text-primary animate-spin text-2xl">progress_activity</span>
                        </div>
                    }
                    else if (_publicRooms.Count > 0)
                    {
                        <div class="flex flex-col gap-2">
                            <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500 dark:text-slate-400 px-2 flex items-center gap-1.5">
                                <span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse inline-block"></span>
                                Dostępne pokoje publiczne
                            </p>
                            @foreach (var room in _publicRooms)
                            {
                                var canJoin = !string.IsNullOrWhiteSpace(_nickname) && !_isLoading;
                                <div class="flex items-center justify-between h-14 px-5 bg-surface-light dark:bg-surface-dark rounded-full border border-slate-200 dark:border-slate-800 shadow-sm">
                                    <div class="flex flex-col">
                                        <span class="text-[10px] font-bold uppercase tracking-tight text-slate-400 dark:text-slate-500 leading-none">Host</span>
                                        <span class="text-sm font-bold text-slate-900 dark:text-white leading-tight">@room.HostNickname</span>
                                    </div>
                                    <div class="flex items-center gap-3">
                                        <div class="flex items-center gap-1">
                                            <span class="material-symbols-outlined text-primary text-sm">group</span>
                                            <span class="text-xs text-slate-500 dark:text-slate-400 font-medium">@room.PlayerCount/@room.MaxPlayers</span>
                                        </div>
                                        <button @onclick="() => JoinPublicRoom(room.Code)"
                                                disabled="@(!canJoin)"
                                                class="@(canJoin ? "bg-primary hover:bg-primary-dark text-white shadow-sm" : "bg-slate-200 dark:bg-slate-700 text-slate-400 dark:text-slate-500 cursor-not-allowed") text-xs font-bold py-2 px-4 rounded-full transition-all btn-press">
                                            Dołącz
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>
                    }

                    @if (_publicRooms.Count > 0)
                    {
                        <!-- Separator -->
                        <div class="flex items-center gap-3 py-1">
                            <div class="h-px flex-1 bg-slate-200 dark:bg-slate-800"></div>
                            <span class="text-[10px] font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest whitespace-nowrap">lub wpisz kod</span>
                            <div class="h-px flex-1 bg-slate-200 dark:bg-slate-800"></div>
                        </div>
                    }

                    <!-- Kod: h-14 rounded-full jak przyciski ekranu 1 -->
                    @if (!string.IsNullOrEmpty(_pendingRoomCode))
                    {
                        <!-- Read-only pre-filled code from URL -->
                        <div class="w-full h-14 px-6 rounded-full bg-primary/10 border border-primary/30 flex items-center justify-center">
                            <span class="text-xl font-black text-primary tracking-[0.35em]">@_roomCode</span>
                        </div>
                    }
                    else
                    {
                        <input @bind="_roomCode"
                               @bind:event="oninput"
                               placeholder="ABCD"
                               maxlength="4"
                               class="w-full h-14 px-6 rounded-full bg-surface-light dark:bg-surface-dark border border-slate-300 dark:border-slate-700 text-slate-900 dark:text-white text-center text-xl font-black uppercase tracking-[0.35em] placeholder:text-slate-300 dark:placeholder:text-slate-600 placeholder:font-normal placeholder:tracking-normal placeholder:text-base focus:border-primary transition-all" />
                    }

                    @{
                        var codeReady = _roomCode.Length == 4 && !string.IsNullOrWhiteSpace(_nickname) && !_isLoading;
                    }
                    <button @onclick="SubmitForm"
                            disabled="@(!codeReady)"
                            class="@(codeReady ? "flex w-full items-center justify-center gap-2 h-14 rounded-full bg-surface-light dark:bg-surface-dark border border-slate-300 dark:border-slate-700 hover:bg-slate-100 dark:hover:bg-slate-800 text-slate-900 dark:text-white font-bold text-lg transition-all btn-press" : "flex w-full items-center justify-center gap-2 h-14 rounded-full bg-slate-100 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 text-slate-400 dark:text-slate-500 cursor-not-allowed font-bold text-lg")">
                        @if (_isLoading)
                        {
                            <div class="w-5 h-5 border-2 border-current border-t-transparent rounded-full animate-spin"></div>
                            <span>Łączę...</span>
                        }
                        else
                        {
                            <span class="material-symbols-outlined text-2xl">vpn_key</span>
                            <span>Dołącz z kodem</span>
                        }
                    </button>

                    @if (!string.IsNullOrEmpty(_error))
                    {
                        <p class="text-center text-red-400 text-sm">@_error</p>
                    }

                </div>
            }

        </div>
    </footer>

</div>

@code {
    private bool _showJoinInput;
    private bool _isCreating;
    private bool _isLoading;
    private bool _isLoadingRooms;
    private string _roomCode = "";
    private string _nickname = "";
    private string? _error;
    private string? _pendingRoomCode;
    private string? _kickedMessage;
    private List<PublicRoomInfo> _publicRooms = new();

    private bool CanSubmit => !string.IsNullOrWhiteSpace(_nickname) &&
                              (_isCreating || _roomCode.Length == 4);

    protected override void OnInitialized()
    {
        GameState.OnError += HandleError;
        GameState.OnPublicRoomsUpdated += HandlePublicRoomsUpdated;
        GameState.OnStateChanged += HandleStateChanged;

        TrySetupDeepLink();

        // Show kicked/error message if redirected here after being kicked
        if (!string.IsNullOrEmpty(GameState.LastError))
        {
            _kickedMessage = GameState.LastError;
            GameState.LastError = null;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && string.IsNullOrEmpty(_nickname))
        {
            var lastNickname = await GameState.GetLastNicknameAsync();
            if (!string.IsNullOrEmpty(lastNickname))
            {
                _nickname = lastNickname;
                StateHasChanged();
            }
        }
    }

    private void HandleError(string error)
    {
        _error = error;
        _isLoading = false;
        InvokeAsync(StateHasChanged);
    }

    private void HandlePublicRoomsUpdated(List<PublicRoomInfo> rooms)
    {
        _publicRooms = rooms;
        InvokeAsync(StateHasChanged);
    }

    private void HandleStateChanged()
    {
        // Re-check deep link after InitializeWithRoomCodeAsync sets RoomCode
        TrySetupDeepLink();
        InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// Check if GameState.RoomCode is set (deep link) and auto-open the join form.
    /// Safe to call multiple times — only activates once.
    /// </summary>
    private void TrySetupDeepLink()
    {
        if (_pendingRoomCode != null) return; // already set up
        if (string.IsNullOrEmpty(GameState.RoomCode) || !string.IsNullOrEmpty(GameState.Nickname)) return;

        _pendingRoomCode = GameState.RoomCode;
        _roomCode = _pendingRoomCode;
        _showJoinInput = true;
        _isCreating = false;
    }

    private async Task ShowNicknameForCreate()
    {
        _showJoinInput = true;
        _isCreating = true;
        _error = null;
        await JS.InvokeVoidAsync("history.pushState", null, "", "/?view=create");
    }

    private async Task ShowJoinInput()
    {
        _showJoinInput = true;
        _isCreating = false;
        _error = null;
        await JS.InvokeVoidAsync("history.pushState", null, "", "/?view=join");
        _isLoadingRooms = true;
        StateHasChanged();

        try
        {
            _publicRooms = await GameState.StartPublicRoomsBrowsingAsync();
        }
        catch
        {
            _publicRooms = new();
        }
        finally
        {
            _isLoadingRooms = false;
        }
    }

    private async Task JoinPublicRoom(string roomCode)
    {
        if (string.IsNullOrWhiteSpace(_nickname) || _isLoading) return;
        _isLoading = true;
        _error = null;
        StateHasChanged();
        try { await GameState.JoinRoomAsync(roomCode, _nickname); }
        catch { _error = "Nie udało się dołączyć."; _isLoading = false; }
    }



    private async Task CancelForm()
    {
        _showJoinInput = false;
        _isCreating = false;
        _roomCode = "";
        _nickname = "";
        _error = null;
        _pendingRoomCode = null;
        await JS.InvokeVoidAsync("history.pushState", null, "", "/");
        _ = GameState.StopPublicRoomsBrowsingAsync();
    }

    private async Task SubmitForm()
    {
        if (!CanSubmit || _isLoading) return;
        _isLoading = true;
        _error = null;
        StateHasChanged();
        try
        {
            if (_isCreating)
                await GameState.CreateRoomAsync(_nickname);
            else
            {
                var code = !string.IsNullOrEmpty(_roomCode) ? _roomCode : _pendingRoomCode ?? "";
                await GameState.JoinRoomAsync(code.ToUpperInvariant(), _nickname);
            }
        }
        catch
        {
            _error = _isCreating ? "Nie udało się utworzyć pokoju." : "Nie udało się dołączyć.";
            _isLoading = false;
        }
    }

    private string GetSubmitButtonClass()
    {
        var baseClass = "flex w-full items-center justify-center rounded-full h-14 px-5 transition-all btn-press";
        if (!CanSubmit || _isLoading)
            return $"{baseClass} bg-slate-200 dark:bg-slate-700 text-slate-400 dark:text-slate-400 cursor-not-allowed";
        return $"{baseClass} bg-primary hover:bg-primary-dark active:scale-[0.98] text-white shadow-lg shadow-primary/25";
    }

    private void GoToHowToPlay() => Navigation.NavigateTo("/how-to-play");

    private void DismissKickedMessage()
    {
        _kickedMessage = null;
    }

    public void Dispose()
    {
        GameState.OnError -= HandleError;
        GameState.OnPublicRoomsUpdated -= HandlePublicRoomsUpdated;
        GameState.OnStateChanged -= HandleStateChanged;
        _ = GameState.StopPublicRoomsBrowsingAsync();
    }
}
