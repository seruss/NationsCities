@* 
    RoundView.razor - SPA Round View
    Converted from GameRound.razor to work with ClientGameStateService
*@
@using NationsCities.Models
@using NationsCities.Services
@inject ClientGameStateService GameState
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Runda @_currentRound - Państwa, Miasta</PageTitle>

@if (GameState.CurrentRoom == null || GameState.CurrentGame == null)
{
    <div class="flex items-center justify-center min-h-screen bg-bg-light dark:bg-bg-dark">
        <div class="flex flex-col items-center gap-4">
            <span class="material-symbols-outlined text-4xl text-primary animate-spin">progress_activity</span>
            <p class="text-slate-500 dark:text-slate-400">Ładowanie rundy...</p>
        </div>
    </div>
}
else
{
    <div class="flex flex-col min-h-screen bg-bg-light dark:bg-bg-dark">
        <!-- Sticky header + countdown bar -->
        <header class="sticky top-0 shrink-0 z-20 bg-bg-light/95 dark:bg-bg-dark/95 backdrop-blur-md border-b border-slate-200/60 dark:border-slate-800/60">
            <div class="flex items-center justify-center px-4 py-3">
                <h2 class="text-base font-bold tracking-tight uppercase text-slate-500 dark:text-slate-400">Runda @_currentRound</h2>
            </div>
            @if (_isCountdownActive && !_stopTriggeredByMe)
            {
                <!-- Thin countdown bar for non-triggerers -->
                <div class="h-1 w-full bg-slate-200 dark:bg-slate-800">
                    <div class="h-full rounded-r-full transition-all duration-1000 linear"
                         style="width: @(Math.Min(100, (_secondsRemaining / 10.0) * 100))%; background: @CounterColor">
                    </div>
                </div>
            }
        </header>

        <!-- Scrollable content -->
        <div class="flex-1 overflow-y-auto no-scrollbar" data-scrollable="true">
            <div class="px-5 py-6 flex flex-col gap-5">
                <!-- Answer Inputs -->
                @foreach (var category in GameState.CurrentGame.Categories)
                {
                    var inputId = $"answer-{category.Name.Replace(" ", "-").ToLowerInvariant()}";
                    <div class="flex flex-col gap-2">
                        <label for="@inputId" class="text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest ml-1">
                            @category.Name
                        </label>
                        <div class="relative group">
                            <input id="@inputId"
                                   type="text"
                                   @bind="@_answers[category.Name]"
                                   @bind:event="oninput"
                                   placeholder="@(GameState.CurrentGame.CurrentLetter)..."
                                   class="w-full border-0 rounded-2xl py-4 px-5 pr-12 text-lg text-slate-900 dark:text-white placeholder:text-slate-400/50 dark:placeholder:text-slate-500/50 focus:outline-none transition-all disabled:opacity-50 @(!string.IsNullOrEmpty(GetAnswer(category.Name)) ? "bg-white dark:bg-slate-800 ring-1 ring-green-400/40 dark:ring-green-600/40 focus:ring-2 focus:ring-green-400/50 dark:focus:ring-green-600/50" : "bg-white dark:bg-slate-800 ring-1 ring-slate-200 dark:ring-slate-700 focus:ring-2 focus:ring-primary/50")"
                                   autocomplete="off"
                                   disabled="@_hasSubmitted" />
                            <span class="absolute right-4 top-1/2 -translate-y-1/2 material-symbols-outlined text-xl transition-colors @(!string.IsNullOrEmpty(GetAnswer(category.Name)) ? "text-green-500" : "text-slate-300 dark:text-slate-600 group-focus-within:text-primary")">@category.Icon</span>
                        </div>
                    </div>
                }

                <!-- Action area (inline, scrolls with content) -->
                <div class="pt-4 pb-8">
                    @if (_isCountdownActive && _stopTriggeredByMe)
                    {
                        <!-- Triggerer: single button that is both countdown bar and +1s action -->
                        <button @onclick="AddOneSecond"
                                class="relative w-full h-14 rounded-xl overflow-hidden bg-slate-200 dark:bg-slate-700 shadow-lg btn-press cursor-pointer border-0">
                            <div class="absolute inset-y-0 left-0 transition-all duration-1000 linear"
                                 style="width: @(Math.Min(100, (_secondsRemaining / 10.0) * 100))%; background: @CounterColor">
                            </div>
                            <div class="absolute inset-0 flex items-center justify-center gap-2">
                                <span class="material-symbols-outlined text-white drop-shadow-sm" style="font-size: 20px;">add_circle</span>
                                <span class="text-white font-bold text-lg drop-shadow-sm">+1 sekunda</span>
                            </div>
                        </button>
                    }
                    else if (_hasSubmitted)
                    {
                        <div class="text-center py-4">
                            <p class="text-lg font-bold text-green-500 dark:text-green-400 flex items-center justify-center gap-2">
                                <span class="material-symbols-outlined">check_circle</span>
                                Odpowiedzi wysłane!
                            </p>
                            <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Czekam na innych graczy...</p>
                        </div>
                    }
                    else if (_isCountdownActive)
                    {
                        <!-- Non-triggerer during countdown: submit button -->
                        <button @onclick="SubmitAnswers"
                                class="w-full flex items-center justify-center gap-2 bg-green-600 hover:bg-green-700 text-white font-bold text-lg py-4 rounded-xl shadow-lg transition-all btn-press">
                            <span class="material-symbols-outlined">send</span>
                            <span>Wyślij odpowiedzi</span>
                        </button>
                    }
                    else
                    {
                        <!-- Normal: STOP button -->
                        <button @onclick="TriggerStop"
                                disabled="@(!CanStop)"
                                class="w-full flex items-center justify-center gap-2 @(CanStop ? "bg-red-500 hover:bg-red-600 shadow-red-500/30" : "bg-slate-200 dark:bg-slate-700 cursor-not-allowed") text-white font-bold text-lg py-4 rounded-xl shadow-lg transition-all btn-press">
                            <span class="material-symbols-outlined">stop_circle</span>
                            <span>STOP!</span>
                        </button>
                        @if (!CanStop)
                        {
                            <p class="text-center text-xs text-orange-400 mt-2">Uzupełnij wszystkie odpowiedzi aby zakończyć</p>
                        }
                    }
                </div>
            </div>
        </div>
    </div>

    @if (_showRerollConfirmation)
    {
        <NationsCities.Components.Game.Shared.ConfirmationModal
            Title="Losować nową literę?"
            Message="Odpowiedzi wszystkich graczy zostaną wyczyszczone."
            ConfirmText="Losuj"
            CancelText="Anuluj"
            OnConfirm="ConfirmReroll"
            OnCancel="CancelReroll" />
    }
}

@code {
    private Dictionary<string, string> _answers = new();
    private int _currentRound = 1;
    private int _secondsRemaining = 10;
    private bool _isCountdownActive = false;
    private bool _hasSubmitted = false;
    private bool _stopTriggeredByMe = false;
    private System.Timers.Timer? _timer;
    private bool _hasInitialized = false;
    private bool _showRerollConfirmation = false;

    // Can only click STOP if all answers are filled
    private bool CanStop => GameState.CurrentGame?.Categories.All(c => !string.IsNullOrWhiteSpace(GetAnswer(c.Name))) ?? false;

    // Color of countdown bar
    private string CounterColor => _secondsRemaining <= 3 ? "#f87171"
                                 : _secondsRemaining <= 6 ? "#fb923c"
                                 : "var(--color-primary)";

    protected override void OnInitialized()
    {
        GameState.OnStateChanged += HandleStateChanged;
        GameState.OnStopTriggered += HandleStopTriggered;
        GameState.OnTimeAdded += HandleTimeAdded;
        GameState.OnRoundEnded += HandleRoundEnded;
        GameState.OnLetterRerolled += HandleLetterRerolled;
        
        InitializeRound();
    }

    private void InitializeRound()
    {
        if (_hasInitialized || GameState.CurrentGame == null) return;
        _hasInitialized = true;
        
        _currentRound = GameState.CurrentGame.CurrentRound;
        
        foreach (var category in GameState.CurrentGame.Categories)
        {
            if (!_answers.ContainsKey(category.Name))
            {
                _answers[category.Name] = "";
            }
        }
        
        // Rejoin scenario
        if (GameState.CurrentGame.Phase == RoundPhase.Countdown && GameState.CurrentGame.CountdownEndTime.HasValue)
        {
            _isCountdownActive = true;
            var remaining = (GameState.CurrentGame.CountdownEndTime.Value - DateTime.UtcNow).TotalSeconds;
            _secondsRemaining = Math.Max(1, (int)Math.Ceiling(remaining));
            _stopTriggeredByMe = GameState.CurrentGame.StopTriggeredBy == GameState.MyPlayer?.SessionId;
            StartTimer();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && GameState.CurrentGame != null)
        {
            await GameState.StartAntiCheatTrackingAsync(_currentRound);

            // If countdown active on mount (rejoin) and not triggerer, start vignette
            if (_isCountdownActive && !_stopTriggeredByMe && !_hasSubmitted)
            {
                try { await JS.InvokeVoidAsync("beatVignette"); } catch { }
            }
        }
    }

    private void HandleStateChanged()
    {
        if (!_hasInitialized && GameState.CurrentGame != null)
        {
            InitializeRound();
        }
        InvokeAsync(StateHasChanged);
    }

    private void HandleStopTriggered(string playerId, DateTime endTime)
    {
        _isCountdownActive = true;
        _stopTriggeredByMe = playerId == GameState.MyPlayer?.SessionId;

        var remaining = (endTime - DateTime.UtcNow).TotalSeconds;
        _secondsRemaining = Math.Max(1, (int)Math.Ceiling(remaining));

        StartTimer();

        // Start vignette for non-triggerers who haven't submitted yet
        if (!_stopTriggeredByMe && !_hasSubmitted)
        {
            _ = InvokeAsync(async () =>
            {
                try { await JS.InvokeVoidAsync("beatVignette"); } catch { }
            });
        }

        InvokeAsync(StateHasChanged);
    }

    private void HandleTimeAdded(DateTime endTime)
    {
        var remaining = (endTime - DateTime.UtcNow).TotalSeconds;
        _secondsRemaining = Math.Max(1, (int)Math.Ceiling(remaining));
        InvokeAsync(StateHasChanged);
    }

    private async void HandleRoundEnded(int answerCount)
    {
        _timer?.Stop();
        _isCountdownActive = false;
        try { await JS.InvokeVoidAsync("clearVignette"); } catch { }
    }

    private void StartTimer()
    {
        _timer?.Stop();
        _timer = new System.Timers.Timer(1000);
        _timer.Elapsed += async (s, e) =>
        {
            if (_secondsRemaining > 0)
            {
                _secondsRemaining--;
                await InvokeAsync(StateHasChanged);
                // Vignette pulse for non-triggerers who haven't submitted
                if (!_stopTriggeredByMe && !_hasSubmitted)
                {
                    try { await JS.InvokeVoidAsync("beatVignette"); } catch { }
                }
            }
            else
            {
                _timer?.Stop();
                _isCountdownActive = false;
                try { await JS.InvokeVoidAsync("clearVignette"); } catch { }
                if (!_hasSubmitted)
                {
                    await SubmitAnswers();
                }
            }
        };
        _timer.Start();
    }

    private async Task TriggerStop()
    {
        if (_hasSubmitted) return;
        _hasSubmitted = true;
        await GameState.PauseAntiCheatTrackingAsync();
        await GameState.TriggerStopAsync(_answers);
        await InvokeAsync(StateHasChanged);
    }

    private async Task AddOneSecond()
    {
        if (_stopTriggeredByMe)
        {
            await GameState.AddTimeAsync(1);
        }
    }

    private async Task SubmitAnswers()
    {
        if (_hasSubmitted) return;
        _hasSubmitted = true;
        await GameState.PauseAntiCheatTrackingAsync();
        await GameState.SubmitAnswersAsync(_answers);
        // Stop vignette on submit
        try { await JS.InvokeVoidAsync("clearVignette"); } catch { }
        await InvokeAsync(StateHasChanged);
    }

    private void ShowRerollConfirmation()
    {
        _showRerollConfirmation = true;
    }

    private async Task ConfirmReroll()
    {
        _showRerollConfirmation = false;
        await GameState.RerollLetterAsync();
    }

    private void CancelReroll()
    {
        _showRerollConfirmation = false;
    }

    private void HandleLetterRerolled(char newLetter)
    {
        foreach (var key in _answers.Keys.ToList())
        {
            _answers[key] = "";
        }
        _hasSubmitted = false;
        InvokeAsync(StateHasChanged);
    }

    private string GetAnswer(string category)
    {
        return _answers.TryGetValue(category, out var answer) ? answer : "";
    }

    public void Dispose()
    {
        GameState.OnStateChanged -= HandleStateChanged;
        GameState.OnStopTriggered -= HandleStopTriggered;
        GameState.OnTimeAdded -= HandleTimeAdded;
        GameState.OnRoundEnded -= HandleRoundEnded;
        GameState.OnLetterRerolled -= HandleLetterRerolled;
        
        _timer?.Stop();
        _timer?.Dispose();
    }
}
