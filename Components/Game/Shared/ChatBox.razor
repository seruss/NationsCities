@* 
    ChatBox.razor - Reusable chat component
    Used in ScoreboardView, FinalResultsView, and LobbyView
*@
@using NationsCities.Models
@using NationsCities.Services
@implements IDisposable
@inject ClientGameStateService GameState

@if (Variant == ChatVariant.Card)
{
    <div>
        @if (ShowHeader)
        {
            <h2 class="text-sm font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400 mb-3 px-1 flex items-center gap-2">
                <span class="material-symbols-outlined text-base">chat</span>
                Czat
            </h2>
        }
        <div class="bg-surface-light dark:bg-surface-dark rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm flex flex-col">
            <div class="overflow-hidden p-3 space-y-2">
                @foreach (var msg in Messages.TakeLast(MaxMessages))
                {
                    <div class="flex gap-2 items-start">
                        <span class="text-xs font-bold @(msg.IsSystem ? "text-primary" : "text-slate-900 dark:text-white") shrink-0">@(msg.IsSystem ? "System:" : $"{msg.Nickname}:")</span>
                        <span class="text-xs text-slate-600 dark:text-slate-300">@msg.Text</span>
                    </div>
                }
                @if (!Messages.Any())
                {
                    <p class="text-xs text-slate-400 dark:text-slate-600 text-center py-2">Brak wiadomości. Napisz coś!</p>
                }
            </div>
            <div class="flex gap-2 items-center border-t border-slate-200 dark:border-slate-700 px-3 py-2">
                <input @bind="_chatInput"
                       @bind:event="oninput"
                       @onkeypress="HandleKeyPress"
                       placeholder="Napisz wiadomość..."
                       class="chat-input flex-1 bg-transparent text-sm text-slate-900 dark:text-white placeholder-slate-400 border-none p-0 focus:ring-0 focus:outline-none" />
                <button @onclick="SendMessage" class="shrink-0 w-8 h-8 flex items-center justify-center rounded-full @(!string.IsNullOrWhiteSpace(_chatInput) ? "text-primary active:bg-primary/20 active:shadow-[0_0_10px_rgba(37,140,244,0.4)]" : "text-slate-400") transition-colors">
                    <span class="material-symbols-outlined text-xl">send</span>
                </button>
            </div>
        </div>
    </div>
}
else
{
    <div class="flex-1 min-h-[120px] bg-surface-light dark:bg-surface-dark rounded-2xl p-3 shadow-inner border border-slate-200 dark:border-slate-800 flex flex-col justify-end">
        <div class="flex-1 overflow-y-auto space-y-2 mb-2 pr-1 no-scrollbar" data-scrollable="true">
            @foreach (var msg in Messages.TakeLast(MaxMessages))
            {
                <div class="flex gap-2 items-start">
                    <span class="text-xs font-bold @(msg.IsSystem ? "text-primary" : "text-slate-900 dark:text-white") shrink-0">@(msg.IsSystem ? "System:" : $"{msg.Nickname}:")</span>
                    <span class="text-xs text-slate-600 dark:text-slate-300">@msg.Text</span>
                </div>
            }
        </div>
        <div class="flex gap-2 items-center bg-slate-100 dark:bg-surface-darker rounded-full px-4 py-2 border border-slate-200 dark:border-slate-700 focus-within:border-primary transition-all">
            <input @bind="_chatInput"
                   @bind:event="oninput"
                   @onkeypress="HandleKeyPress"
                   placeholder="Napisz wiadomość..."
                   class="chat-input flex-1 bg-transparent text-sm text-slate-900 dark:text-white placeholder-slate-400 border-none p-0 focus:ring-0 focus:outline-none" />
            <button @onclick="SendMessage" class="shrink-0 w-8 h-8 flex items-center justify-center rounded-full @(!string.IsNullOrWhiteSpace(_chatInput) ? "text-primary active:bg-primary/20 active:shadow-[0_0_10px_rgba(37,140,244,0.4)]" : "text-slate-400") transition-colors">
                <span class="material-symbols-outlined text-xl">send</span>
            </button>
        </div>
    </div>
}

@code {
    public enum ChatVariant { Card, Inline }

    [Parameter] public ChatVariant Variant { get; set; } = ChatVariant.Card;
    [Parameter] public bool ShowHeader { get; set; } = true;
    [Parameter] public int MaxMessages { get; set; } = 20;

    private string _chatInput = "";

    private List<ChatMessage> Messages => GameState.CurrentRoom?.ChatMessages ?? new List<ChatMessage>();

    protected override void OnInitialized()
    {
        GameState.OnChatMessage += HandleChatMessage;
    }

    private void HandleChatMessage(string nickname, string msg, bool isSystem)
    {
        InvokeAsync(StateHasChanged);
    }

    private async Task SendMessage()
    {
        if (!string.IsNullOrWhiteSpace(_chatInput))
        {
            await GameState.SendChatMessageAsync(_chatInput);
            _chatInput = "";
        }
    }

    private async Task HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SendMessage();
    }

    public void Dispose()
    {
        GameState.OnChatMessage -= HandleChatMessage;
    }
}
